{
  "name": "wdio-vscode-service",
  "version": "7.0.0",
  "description": "A service to test VSCode extensions from end to end",
  "author": "Christian Bromann <mail@bromann.dev>",
  "homepage": "https://github.com/webdriverio-community/wdio-vscode-service",
  "license": "MIT",
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typeScriptVersion": "3.8.3",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "run-s build:*",
    "build:ts": "tsc -b .",
    "build:compile": "pkg --target node18-win --out-path ./dist/chromium ./dist/chromium/index.js",
    "build:chmod": "chmod +x ./dist/chromium/index.js",
    "ci": "run-s test:lint build test",
    "clean": "rimraf ./node_modules ./dist",
    "docs": "typedoc",
    "release": "release-it --github.release",
    "release:ci": "npm run release -- --ci --npm.skipChecks --no-git.requireCleanWorkingDir",
    "release:patch": "npm run release -- patch",
    "release:minor": "npm run release -- minor",
    "release:major": "npm run release -- major",
    "test": "run-s test:*",
    "test:setup": "node ./.github/scripts/link.mjs",
    "test:lint": "eslint src test",
    "test:e2e": "run-s test:e2e:*",
    "test:e2e:run": "wdio run ./test/wdio.conf.ts",
    "test:e2e:cleanup": "git checkout -- package.json",
    "watch": "npm run build:ts -- --watch"
  },
  "keywords": [
    "webdriverio",
    "wdio",
    "wdio-service",
    "vscode",
    "tests"
  ],
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@types/ws": "^8.5.11",
    "@vscode/test-electron": "^3.0.0",
    "@wdio/logger": "^9.0.0",
    "@xhmikosr/downloader": "^16.2.0",
    "decamelize": "6.0.0",
    "fastify": "^5.8.5",
    "get-port": "7.1.0",
    "hpagent": "^1.2.0",
    "semver": "^7.7.2",
    "slash": "^5.1.0",
    "tinyclip": "^0.1.12",
    "tmp-promise": "^3.0.3",
    "undici": "^8.5.0",
    "vscode-uri": "^3.0.8",
    "ws": "^8.18.0",
    "yargs-parser": "^22.0.0"
  },
  "peerDependencies": {
    "webdriverio": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "webdriverio": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "@yao-pkg/pkg": "^6.20.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-base-typescript": "^1.1.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^68.0.0",
    "eslint-plugin-wdio": "^9.29.0",
    "husky": "^9.1.1",
    "npm-run-all2": "^9.0.2",
    "release-it": "^20.2.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.16.2",
    "typedoc": "^0.26.4",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist/*",
    "src/server/fs-provider"
  ]
}
